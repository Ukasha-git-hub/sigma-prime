<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit chats</title>
</head>

<body>
    <h3> edit your chat:<%= find.id %>
    </h3>

    <form method="post" action="/chat/<%= find._id %>?_method=PUT">
        <textarea name="msg"><%= find.msg %></textarea>
        <br>
        <button>send</button>
    </form>
</body>

</html>