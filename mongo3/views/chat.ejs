<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp</title>
    <link rel="stylesheet" href="style.css">

</head>

<body>
    <h2>All chats</h2>
    <form method="get" action="/chat/new">
        <button>new chat</button>
    </form>
    <% for(let chat of chats) { %>
        <div class="chat">
            <p><b>from: <%= chat.from %></b>
            </p>
            <div class="msg">
                <p> message : <%= chat.msg %>
                </p>
                <form method="get" action="/chat/<%= chat._id %>/edit">
                    <button>Edit</button>

                </form>
                <br>
                <form method="post" action="/chat/<%= chat._id %>?_method=Delete">

                    <button>Delete chat</button>
                </form>

            </div>
            <div class="to">
                <p><b> Recieved By: <%= chat.to %></b>
                </p>
            </div>

            <hr>
            <p>Time :<%= chat.time.toString().split(" ")[4] %>   
            </p>
             <p>Date :<%= chat.time.toString().split(" ").slice(0,4) .join(" -")%>
            </p>
        </div>

        <br>
        <br>

        <% } %>
</body>

</html>