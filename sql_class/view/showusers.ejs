<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All users</title>
    <style>
        table,
        tr,
        th,
        td {
            border: 2px solid black;
        }
    </style>
</head>

<body>
    <table>
        <tr>
            <th>id</th>
            <th>name</th>
            <th>email</th>
        </tr>
        <% for(let res of result){ %>
            <tr>
                <td>
                    <%=res.id %>
                </td>
                <td>
                    <%= res.username %>
                        </res>
                </td>
                <td>
                    <%= res.email %>
                </td>
                <td>
                    <form method="GET" action="/user/<%= res.id %>/edit">
                        <button>edit user</button>
                    </form>
                </td>
            </tr>
            <% } %>
    </table>
</body>

</html>